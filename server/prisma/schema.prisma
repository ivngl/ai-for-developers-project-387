generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model EventType {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  duration    Int
  date        String?
  startTime   String?
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id          Int       @id @default(autoincrement())
  eventTypeId Int
  eventType   EventType @relation(fields: [eventTypeId], references: [id])
  guestName   String?
  guestEmail  String?
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([eventTypeId])
  @@index([startTime, endTime])
}
